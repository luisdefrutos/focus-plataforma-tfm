# =========================================================================
# Variables de entorno — Proyecto Focus
# =========================================================================
# Copia este fichero a .env y rellena los valores. .env NO va al repositorio.
# =========================================================================

# MySQL local (desarrollo). Cambiar password antes de usar.
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# IMPORTANTE: caracteres especiales en la password se URL-encodean (#->%23, @->%40, /->%2F, :->%3A, etc.)
DATABASE_URL="mysql://focus_app:CHANGEME@localhost:3306/focus_dev"

# Shadow DB usada por `prisma migrate dev` para dry-runs (debe existir y el usuario debe tener permisos).
SHADOW_DATABASE_URL="mysql://focus_app:CHANGEME@localhost:3306/focus_dev_shadow"

# NextAuth — OBLIGATORIO. Sin NEXTAUTH_SECRET el token de sesión no se firma de
# forma estable (warnings y sesiones que se invalidan al reiniciar).
# Genera uno: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="CHANGEME-genera-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# ── Active Directory (login por LDAP directo contra los DCs — backend por defecto) ──
# Search-then-bind: la cuenta de servicio busca el usuario por sAMAccountName bajo
# el base DN y el login es un re-bind con el DN encontrado + la contraseña del
# usuario. El alta en /accesos usa la misma búsqueda para autorrellenar nombre/email.
# URLs LDAPS en orden de preferencia (failover solo ante errores de conexión):
# AD_LDAP_URLS="ldaps://dc1.tuv-sud.es:636,ldaps://dcback.tuv-sud.es:636"   (default)
# AD_LDAP_BASE_DN="OU=ES,DC=ww001,DC=itgr,DC=net"                           (default)
# Cuenta de servicio para la búsqueda previa. OBLIGATORIAS: sin ellas el login y
# el alta fallan. Pídelas a IT. NO se versionan.
AD_LDAP_BIND_DN="CHANGEME-dn-cuenta-de-servicio"
AD_LDAP_BIND_PASSWORD="CHANGEME-password-cuenta-de-servicio"
# TLS: si el certificado del DC lo emite la CA corporativa y Node no la conoce,
# apunta AD_LDAP_CA_FILE al PEM de esa CA. Desactivar la verificación
# (AD_LDAP_TLS_REJECT_UNAUTHORIZED=false) SOLO como último recurso (riesgo MITM).
# AD_LDAP_CA_FILE=""
# AD_LDAP_TLS_REJECT_UNAUTHORIZED="false"
# Timeout de conexión/operación LDAP en ms (opcional, por defecto 10000).
# AD_LDAP_TIMEOUT_MS="10000"

# ── Active Directory vía web service SOAP (LEGADO — rollback) ──
# Backend anterior (src/lib/ad-soap.ts); se activa con AD_AUTH_BACKEND=soap y
# requiere entonces AD_SOAP_URL ("https://gestion.atisae.com/loginwebservice/login.asmx")
# y AD_SOAP_LDAP_KEY (la clave del passport MD5, la tiene IT). Solo funciona donde
# ese endpoint sea alcanzable (desde el servidor de producción NO lo es).
# AD_AUTH_BACKEND="soap"

# Login mock SOLO para desarrollo sin conectividad al web service de AD: si se
# pone a "true", NO se valida la contraseña (cualquiera con un username dado de
# alta entra). Déjalo sin definir salvo que sepas lo que haces: por defecto el
# login va SIEMPRE contra AD por SOAP, en todos los entornos.
# AUTH_ALLOW_MOCK="true"

# Secreto opcional para POST /api/revalidate desde scripts/CI tras re-seedear (sin
# sesión). Si no se define, el endpoint solo acepta sesión con permiso DATA_MANAGE.
# Envíalo en la cabecera `x-revalidate-secret`.
# REVALIDATE_SECRET="CHANGEME-secreto-de-revalidacion"
